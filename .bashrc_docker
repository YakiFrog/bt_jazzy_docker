# Behavior Tree Docker Container 用のエイリアス設定

# .bashrc_docker に追記例
export ROS_DOMAIN_ID=56

# 基本コマンド
alias build='colcon build --symlink-install'
alias src='source install/setup.bash'
alias tt='source ~/.bashrc'

# 自動で環境を読み込む
if [ -f "/ros2_ws/install/setup.bash" ]; then
    source "/ros2_ws/install/setup.bash"
fi

# サンプル実行用
alias run_logic='ros2 launch bt_logic action_logic.launch.py'
alias run_bt='ros2 run bt_core bt_node'
alias create_action='/ros2_ws/create_action.py'

# 便利設定
export RCUTILS_COLORIZED_OUTPUT=1
echo "--- BT Dev Environment Loaded ---"
echo "Available aliases: build, src, run_logic, run_bt"
