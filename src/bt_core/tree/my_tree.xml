<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="MainTree">
    <Sequence>
      <SaySomething message="XMLファイルからミッションを開始します。(3, 3)へ移動！"/>
      <MoveToTarget x="3.0"
                    y="3.0"/>
      <SaySomething message="到着。次は (-2, 4) へ。"/>
      <MoveToTarget x="-2.0"
                    y="4.0"/>
      <SaySomething message="すべての目標地点を回りました。ミッション終了。"/>
      <CheckBattery tekito=""/>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Condition ID="CheckBattery">
      <input_port name="tekito"
                  type="float"/>
    </Condition>
    <Action ID="MoveToTarget">
      <input_port name="x"
                  type="float"/>
      <input_port name="y"
                  type="float"/>
    </Action>
    <Action ID="SaySomething">
      <input_port name="message"
                  type="std::string"/>
    </Action>
  </TreeNodesModel>

</root>
