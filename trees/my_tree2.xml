<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="MainTree2">
    <Sequence>
      <SaySomething message="出発するぞ！"/>
      <MoveToPose x="5.0"
                  y="0.0"
                  degrees="0.0"/>
      <MoveToPose x="5.0"
                  y="-4.0"
                  degrees="180"/>
      <SaySomething message="戻るのだ！"/>
      <MoveToPose x="-0.5"
                  y="-4.0"
                  degrees="90"/>
      <MoveToPose x="0.0"
                  y="0.0"
                  degrees="0.0"/>
      <SaySomething message="ただいまなのだ！"/>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="MoveToPose">
      <input_port name="x"
                  type="float">目的地のX座標 [m]</input_port>
      <input_port name="y"
                  type="float">目的地のY座標 [m]</input_port>
      <input_port name="degrees"
                  default="0.0"
                  type="float">目的地の向き [度] (0=正面向き, 90=左, -90=右, 180=後ろ向き)</input_port>
    </Action>
    <Action ID="SaySomething">
      <input_port name="message"
                  type="std::string"/>
    </Action>
  </TreeNodesModel>

</root>
