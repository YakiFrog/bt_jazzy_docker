<root BTCPP_format="4">
    <TreeNodesModel>
        <Action ID="MoveToPose">
            <input_port name="x" type="float">目的地のX座標 [m]</input_port>
            <input_port name="y" type="float">目的地のY座標 [m]</input_port>
            <input_port name="yaw" type="float">目的地の向き (Yaw) [rad] (オプション)</input_port>
            Nav2を用いて障害物回避をしながら目標姿勢へと自律移動します。
        </Action>
        <Action ID="SetFaceExpression">
            <input_port name="expression" type="std::string">変更する表情名 (例: happy, wink, pien)</input_port>
            Siriusの顔表情を指定した状態に切り替えます。
        </Action>
        <Condition ID="CheckBattery">
            <input_port name="tekito" type="float">バッテリー残量の判定しきい値</input_port>
            バッテリー残量がしきい値以上残っているかを判定します。
        </Condition>
        <Action ID="SaySomething">
            <input_port name="message" type="std::string">喋らせるセリフ (例: [happy]こんにちは！)</input_port>
            Siriusに感情タグ付きのメッセージを喋らせます（音声出力・字幕・口パク完了まで待機します）。
        </Action>
        <Action ID="MoveToTarget">
            <input_port name="x" type="float">目標のX座標 [m]</input_port>
            <input_port name="y" type="float">目標のY座標 [m]</input_port>
            オドメトリのみを参照し、P制御で目標値へ直進移動します（障害物回避なし・デバッグ用）。
        </Action>
        <Action ID="RotateDegrees">
            <input_port name="degrees" type="float">旋回する角度 [度]</input_port>
            その場で指定された角度（度数法）だけP制御で旋回します。
        </Action>
        <Action ID="PickUpItem">
            <input_port name="item" type="std::string">対象アイテム名</input_port>
            指定したアイテムを拾い上げる模擬アクションです。
        </Action>
        <Action ID="CleanRoom">
            <input_port name="whichroom" type="std::string">対象の部屋名</input_port>
            指定した部屋を掃除する模擬アクションです。
        </Action>
        <Action ID="TekitoAction">
            <input_port name="tekitodane" type="int">任意のテスト用値</input_port>
            サンプルのテスト用アクションノードです。
        </Action>
    </TreeNodesModel>
</root>
